generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")     // Usa Pooling para las consultas rápidas de tu app
  directUrl = env("POSTGRES_URL_NON_POOLING") // Conexión directa (necesaria para migraciones)
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  category    String   // "remeras", "pantalones", "gorras", "conjuntos", "zapatillas", "abrigo", "accesorios"
  price       Float
  images      String   @db.Text // JSON string of image URLs
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
}
